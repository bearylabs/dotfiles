[
  {
    "key": "space",
    "command": "whichkey.show",
    "when": "focusedView == '' && !whichkeyActive && !inputFocus && (!auxiliaryBarVisible || view.workbench.panel.chat.view.copilot.visible)"
  },
  {
    "key": "space",
    "command": "whichkey.show",
    "when": "sideBarFocus && !inputFocus && !whichkeyActive || view.workbench.panel.markers.view.visible && !inputFocus"
  },
  {
    "key": "alt+space",
    "command": "whichkey.show",
    "when": "inDebugRepl || terminalFocus|| view.workbench.panel.markers.view.visible && inputFocus || vim.mode = 'insert'"
  },
  {
    "key": "alt+shift+space",
    "command": "whichkey.show",
    "when": "inDebugRepl || terminalFocus|| view.workbench.panel.markers.view.visible && inputFocus || vim.mode = 'insert'"
  },
  {
    "key": "t",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "t",
      "when": "activePanel == 'terminal'"
    },
    "when": "whichkeyVisible && activePanel == 'terminal'"
  },
  {
    "key": "shift+t",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "T",
      "when": "activePanel == 'terminal'"
    },
    "when": "whichkeyVisible && activePanel == 'terminal'"
  },
  {
    "key": "shift+l",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "L",
      "when": "multipleEditorGroups"
    },
    "when": "whichkeyVisible && multipleEditorGroups"
  },
  {
    "key": "shift+h",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "H",
      "when": "multipleEditorGroups"
    },
    "when": "whichkeyVisible && multipleEditorGroups"
  },
  {
    "key": "shift+j",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "J",
      "when": "multipleEditorGroups"
    },
    "when": "whichkeyVisible && multipleEditorGroups"
  },
  {
    "key": "shift+k",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "K",
      "when": "multipleEditorGroups"
    },
    "when": "whichkeyVisible && multipleEditorGroups"
  },
  {
    "key": "p",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "p",
      "when": "explorerViewletVisible"
    },
    "when": "whichkeyVisible && explorerViewletVisible"
  },
  {
    "key": "d",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "d",
      "when": "activeViewlet == 'workbench.view.debug'"
    },
    "when": "whichkeyVisible && activeViewlet == 'workbench.view.debug'"
  },
  {
    "key": "a",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "a",
      "when": "editorHasSelection"
    },
    "when": "whichkeyVisible && editorHasSelection"
  },
  {
    "key": "a",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "a",
      "when": "view.workbench.panel.chat.view.copilot.visible"
    },
    "when": "whichkeyVisible && view.workbench.panel.chat.view.copilot.visible"
  },
  {
    "key": "x",
    "command": "whichkey.triggerKey",
    "args": {
      "key": "x",
      "when": "view.workbench.panel.markers.view.visible"
    },
    "when": "whichkeyVisible && view.workbench.panel.markers.view.visible"
  },
  {
    "key": "c f",
    "command": "explorer.newFile",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "command": "renameFile",
    "key": "shift+r",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "command": "workbench.files.action.refreshFilesExplorer",
    "key": "r",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "c d",
    "command": "explorer.newFolder",
    "when": "explorerViewletFocus"
  },
  {
    "command": "deleteFile",
    "key": "d",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "command": "workbench.action.closeActiveEditor",
    "key": "d",
    "when": "openEditorsFocus && !inputFocus"
  },
  {
    "key": "shift+d",
    "command": "runCommands",
    "args": {
      "commands": [
        "workbench.action.closeGroup",
        "workbench.action.closeSidebar"
      ]
    },
    "when": "openEditorsFocus && !inputFocus"
  },
  {
    "command": "workbench.action.closeActiveEditor",
    "key": "c",
    "when": "openEditorsFocus && !inputFocus"
  },
  {
    "key": "enter",
    "command": "runCommands",
    "args": {
      "commands": [
        "list.select",
        "workbench.action.closeSidebar"
      ]
    },
    "when": "openEditorsFocus && !inputFocus"
  },
  {
    "key": "escape",
    "command": "workbench.action.closeSidebar",
    "when": "(sideBarVisible && !explorerViewletVisible && !view.workbench.explorer.openEditorsView.visible)"
  },
  {
    "key": "escape",
    "command": "workbench.action.closeSidebar",
    "when": "sideBarFocus && activeViewlet == 'workbench.view.debug' && !inputFocus"
  },
  {
    "key": "escape",
    "command": "workbench.action.closeAuxiliaryBar",
    "when": "auxiliaryBarVisible && !inputFocus" // workaround: always closes the aux bar, otherwise codex and gemini aren't detected
  },
  {
    "key": "q",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "filesExplorerFocus && !inputFocus"
  },
  {
    "key": "q",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "openEditorsFocus && !inputFocus"
  },
  {
    "key": "q",
    "command": "workbench.action.togglePanel",
    "when": "timelineFocused && !inputFocus"
  },
  {
    "key": "w",
    "command": "workbench.action.closePanel",
    "when": "panelFocus && !inputFocus"
  },
  {
    "key": "escape",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+escape",
    "command": "workbench.action.terminal.sendSequence",
    "args": {
      "text": "\u001b"
    },
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+h",
    "command": "workbench.action.quickInputBack",
    "when": "inQuickInput && !whichkeyVisible"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickInput && !whichkeyVisible"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickInput && !whichkeyVisible"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.acceptSelectedQuickOpenItem",
    "when": "inQuickInput && !whichkeyVisible"
  },
]