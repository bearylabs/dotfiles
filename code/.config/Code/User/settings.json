{
  "window.newWindowProfile": "Default",
  "window.restoreWindows": "none",
  "workbench.colorTheme": "Catppuccin Macchiato",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.preferredDarkColorTheme": "Catppuccin Macchiato",
  "workbench.preferredLightColorTheme": "Catppuccin Latte",
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Symbols Nerd Font', monospace",
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "http.systemCertificatesNode": true,
  "update.mode": "none",
  "chat.unifiedAgentsBar.enabled": true,
  "chat.viewSessions.orientation": "stacked",
  "material-icon-theme.folders.color": "#42a5f5",
  "material-icon-theme.folders.theme": "classic",
  "projectManager.git.baseFolders": [
    "~/"
  ],
  "sqldeveloper.datagrid.fontFamily": "'JetBrainsMono Nerd Font', 'Symbols Nerd Font', monospace",
  "vim.useSystemClipboard": true,
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<space>"
      ],
      "commands": [
        "doom.whichKeyShow"
      ]
    },
  ],
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "json.schemaDownload.trustedDomains": {
    "https://developer.microsoft.com/json-schemas/": true,
    "https://esm.sh": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://www.schemastore.org/": true
  },
  "vim.leader": "<space>",
  "todohighlight.defaultStyle": {
    "backgroundColor": "transparent",
    "fontWeight": "bold"
  },
  "todohighlight.keywords": [
    {
      "text": "TODO:",
      "color": "#eed49f",
      "backgroundColor": "transparent",
      "overviewRulerColor": "rgba(238,212,159,0.8)",
      "fontWeight": "bold"
    },
    {
      "text": "FIXME:",
      "color": "#ed8796",
      "backgroundColor": "transparent",
      "overviewRulerColor": "rgba(237,135,150,0.8)",
      "fontWeight": "bold"
    },
    {
      "text": "NOTE:",
      "color": "#a6da95",
      "backgroundColor": "transparent",
      "overviewRulerColor": "rgba(166,218,149,0.8)",
      "fontWeight": "bold"
    },
    {
      "text": "REVIEW:",
      "color": "#c6a0f6",
      "backgroundColor": "transparent",
      "overviewRulerColor": "rgba(198,160,246,0.8)",
      "fontWeight": "bold"
    },
    {
      "text": "HACK:",
      "color": "#f5a97f",
      "backgroundColor": "transparent",
      "overviewRulerColor": "rgba(245,169,127,0.8)",
      "fontWeight": "bold"
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<space>"
      ],
      "commands": [
        "doom.whichKeyShow"
      ]
    }
  ],
  "claudeCode.preferredLocation": "panel",
  "debug.openDebug": "neverOpen",
  "debug.internalConsoleOptions": "neverOpen",
  "debug.console.closeOnEnd": true,
  "debug.toolBarLocation": "docked",
  "window.menuBarVisibility": "compact",
  "scm.diffDecorations": "all",
}