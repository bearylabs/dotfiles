{
  // ===== Vim (Evil-like) =====
  "vim.leader": "<space>",
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.useCtrlKeys": true,
  "vim.whichwrap": "",
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<space>"
      ],
      "commands": [
        "whichkey.show"
      ]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<space>"
      ],
      "commands": [
        "whichkey.show"
      ]
    }
  ],
  "whichkey.delay": 800,
  "whichkey.sortOrder": "alphabetically",
  "whichkey.bindingOverrides": [
    {
      "keys": "o",
      "name": "+Open",
      "type": "bindings",
      "bindings": [
        {
          "key": "t",
          "name": "Toggle terminal popup",
          "type": "command",
          "command": "workbench.action.terminal.toggleTerminal"
        },
        {
          "key": "T",
          "name": "Open terminal here",
          "type": "command",
          "command": "workbench.action.createTerminalEditor"
        },
        {
          "key": "p",
          "name": "Project sidebar",
          "type": "conditional",
          "bindings": [
            {
              "key": "",
              "name": "default",
              "type": "command",
              "command": "workbench.view.explorer"
            },
            {
              "key": "when:explorerViewletVisible",
              "name": "Hide sidebar",
              "type": "command",
              "command": "workbench.action.toggleSidebarVisibility"
            }
          ]
        },
        {
          "key": "d",
          "name": "Start a debugger",
          "type": "conditional",
          "bindings": [
            {
              "key": "",
              "name": "default",
              "type": "command",
              "command": "workbench.view.debug"
            },
            {
              "key": "when:activeViewlet == 'workbench.view.debug'",
              "name": "Hide sidebar",
              "type": "command",
              "command": "workbench.action.toggleSidebarVisibility"
            }
          ]
        },
        {
          "key": "D",
          "name": "Open debug console",
          "type": "command",
          "command": "workbench.debug.action.toggleRepl"
        },
        {
          "key": "a",
          "name": "+AI",
          "type": "bindings",
          "bindings": [
            {
              "key": "c",
              "name": "Open Codex Chat",
              "type": "command",
              "command": "chatgpt.openSidebar"
            },
            {
              "key": "a",
              "name": "Toggle Copilot Chat",
              "type": "conditional",
              "bindings": [
                {
                  "key": "",
                  "name": "default",
                  "type": "command",
                  "command": "workbench.action.chat.open"
                },
                {
                  "key": "when:view.workbench.panel.chat.view.copilot.visible",
                  "name": "Close Copilot Chat",
                  "type": "command",
                  "command": "workbench.action.closeAuxiliaryBar"
                }
              ]
            },
            {
              "key": "g",
              "name": "Open Gemini Chat",
              "type": "command",
              "command": "cloudcode.gemini.chatView.focus"
            }
          ]
        }
      ]
    },
    {
      "keys": "p.o",
      "name": "Open folder",
      "type": "command",
      "command": "workbench.action.files.openFolder"
    },
    {
      "keys": "w.c",
      "name": "Close window",
      "type": "command",
      "command": "workbench.action.closeGroup"
    },
    {
      "keys": "w.d",
      "name": "Close window",
      "type": "command",
      "command": "workbench.action.closeGroup"
    },
    {
      "keys": "w.H",
      "name": "window-move-left",
      "type": "conditional",
      "bindings": [
        {
          "key": "",
          "name": "default",
          "type": "command",
          "command": "workbench.action.moveEditorToLeftGroup"
        },
        {
          "key": "when:multipleEditorGroups",
          "name": "Move group left",
          "type": "command",
          "command": "workbench.action.moveActiveEditorGroupLeft"
        }
      ]
    },
    {
      "keys": "w.J",
      "name": "window-move-down",
      "type": "conditional",
      "bindings": [
        {
          "key": "",
          "name": "default",
          "type": "command",
          "command": "workbench.action.moveEditorToBelowGroup"
        },
        {
          "key": "when:multipleEditorGroups",
          "name": "Move group down",
          "type": "command",
          "command": "workbench.action.moveActiveEditorGroupDown"
        }
      ]
    },
    {
      "keys": "w.K",
      "name": "window-move-up",
      "type": "conditional",
      "bindings": [
        {
          "key": "",
          "name": "default",
          "type": "command",
          "command": "workbench.action.moveEditorToAboveGroup"
        },
        {
          "key": "when:multipleEditorGroups",
          "name": "Move group up",
          "type": "command",
          "command": "workbench.action.moveActiveEditorGroupUp"
        }
      ]
    },
    {
      "keys": "w.L",
      "name": "window-move-right",
      "type": "conditional",
      "bindings": [
        {
          "key": "",
          "name": "default",
          "type": "command",
          "command": "workbench.action.moveEditorToRightGroup"
        },
        {
          "key": "when:multipleEditorGroups",
          "name": "Move group right",
          "type": "command",
          "command": "workbench.action.moveActiveEditorGroupRight"
        }
      ]
    },
    {
      "keys": "w.w",
      "name": "window-next",
      "type": "command",
      "command": "workbench.action.focusNextGroup"
    },
    {
      "keys": "w.W",
      "name": "window-prev",
      "type": "command",
      "command": "workbench.action.focusPreviousGroup"
    },
    {
      "keys": "b.b",
      "name": "Switch workspace buffer",
      "type": "command",
      "command": "workbench.action.showEditorsInActiveGroup"
    },
    {
      "keys": "b.i",
      "name": "iBuffer",
      "type": "command",
      "command": "workbench.files.action.focusOpenEditorsView"
    },
    {
      "keys": "b.B",
      "name": "Switch buffer",
      "type": "command",
      "command": "workbench.action.showAllEditors"
    },
    {
      "keys": "b.D",
      "name": "Kill all buffers",
      "type": "command",
      "command": "runCommands",
      "args": {
        "commands": [
          "workbench.action.closeAllEditors",
          "workbench.action.closeAllGroups"
        ]
      }
    },
    {
      "keys": "b.K",
      "name": "Kill all buffers",
      "type": "command",
      "command": "runCommands",
      "args": {
        "commands": [
          "workbench.action.closeAllEditors",
          "workbench.action.closeAllGroups"
        ]
      }
    },
    {
      "keys": "*",
      "name": "search for symbol in proj",
      "type": "command",
      "command": "workbench.action.showAllSymbols"
    },
    {
      "keys": "s.u",
      "name": "History",
      "type": "command",
      "command": "timeline.focus"
    },
    {
      "keys": "s.p",
      "name": "Search Project",
      "type": "command",
      "command": "search.action.openNewEditor"
    },
    {
      "keys": ":",
      "name": "M-x",
      "type": "command",
      "command": "workbench.action.showCommands"
    },
    {
      "keys": "`",
      "name": "switch to last buffer",
      "type": "command",
      "command": "runCommands",
      "args": {
        "commands": [
          "workbench.action.quickOpenPreviousRecentlyUsedEditorInGroup",
          "list.select"
        ]
      }
    },
    {
      "keys": "c",
      "name": "+Code",
      "type": "bindings",
      "bindings": [
        {
          "key": "c",
          "name": "Compile",
          "type": "command",
          "command": "workbench.action.tasks.build"
        },
        {
          "key": "d",
          "name": "Jump to definition",
          "type": "command",
          "command": "editor.action.revealDefinition"
        },
        {
          "key": "D",
          "name": "Jump to references",
          "type": "command",
          "command": "editor.action.goToReferences"
        },
        {
          "key": "f",
          "name": "Format buffer/region",
          "type": "conditional",
          "bindings": [
            {
              "key": "editorHasSelection",
              "name": "Format selection",
              "type": "command",
              "command": "editor.action.formatSelection"
            },
            {
              "key": "",
              "name": "Format document",
              "type": "command",
              "command": "editor.action.formatDocument"
            }
          ]
        },
        {
          "key": "i",
          "name": "Find implementations",
          "type": "command",
          "command": "editor.action.goToImplementation"
        },
        {
          "key": "t",
          "name": "Find type definition",
          "type": "command",
          "command": "editor.action.goToTypeDefinition"
        },
        {
          "key": "w",
          "name": "Delete trailing whitespace",
          "type": "command",
          "command": "editor.action.trimTrailingWhitespace"
        },
        {
          "key": "x",
          "name": "List errors",
          "type": "conditional",
          "bindings": [
            {
              "key": "",
              "name": "default",
              "type": "command",
              "command": "workbench.actions.view.problems"
            },
            {
              "key": "when:view.workbench.panel.markers.view.visible",
              "name": "Hide problems",
              "type": "command",
              "command": "workbench.action.closePanel"
            }
          ]
        }
      ]
    },
    {
      "keys": [
        "."
      ],
      "name": "Find file",
      "type": "command",
      "command": "workbench.action.files.openFile"
    },
    {
      "keys": " ",
      "name": "Find file in project",
      "type": "command",
      "command": "workbench.action.quickOpen"
    },
    {
      "keys": "<",
      "name": "Switch buffer",
      "type": "command",
      "command": "workbench.action.showAllEditors"
    },
    {
      "keys": "\t",
      "name": "+Workspace",
      "type": "bindings",
      "bindings": [
        {
          "key": "\t",
          "name": "Display workspaces",
          "type": "command",
          "command": "workbench.action.switchWindow"
        },
        {
          "key": "n",
          "name": "New Workspace",
          "type": "command",
          "command": "workbench.action.newWindow"
        }
      ]
    },
    {
      "keys": "!",
      "position": -1,
    },
    {
      "keys": "0",
      "position": -1
    },
    {
      "keys": "1",
      "position": -1
    },
    {
      "keys": "2",
      "position": -1
    },
    {
      "keys": "3",
      "position": -1
    },
    {
      "keys": "4",
      "position": -1
    },
    {
      "keys": "5",
      "position": -1
    },
    {
      "keys": "6",
      "position": -1
    },
    {
      "keys": "7",
      "position": -1
    },
    {
      "keys": "8",
      "position": -1
    },
    {
      "keys": "9",
      "position": -1
    },
    {
      "keys": "b.H",
      "position": -1
    },
    {
      "keys": "b.J",
      "position": -1
    },
    {
      "keys": "b.L",
      "position": -1
    }
  ],
  // ===== Editor Settings =====
  "editor.suggestSelection": "first",
  "editor.inlineSuggest.enabled": true,
  "editor.quickSuggestionsDelay": 10,
  "editor.hover.delay": 100,
  "editor.stickyScroll.enabled": false,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "editor.minimap.enabled": false,
  //
  // ===== Git =====
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  // ===== End =====
  //
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "window.restoreWindows": "none",
  "material-icon-theme.folders.color": "#42a5f5",
  "material-icon-theme.folders.theme": "classic",
  "projectManager.git.baseFolders": [
    "~/"
  ],
  "editor.fontFamily": "'JetBrainsMono Nerd Font', 'Symbols Nerd Font', monospace",
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
  "terminal.integrated.defaultProfile.linux": "fish",
  "terminal.integrated.commandsToSkipShell": [
    "whichkey.show"
  ],
  "workbench.colorTheme": "Catppuccin Macchiato",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "workbench.editor.closeEmptyGroups": false,
  "workbench.editor.enablePreview": false,
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "breadcrumbs.enabled": false,
  "http.systemCertificatesNode": true,
  "update.mode": "none",
  "workbench.editor.showTabs": "none",
  "chat.unifiedAgentsBar.enabled": true,
  "sqldeveloper.datagrid.fontFamily": "'JetBrainsMono Nerd Font', 'Symbols Nerd Font', monospace",
  "chat.viewSessions.orientation": "stacked",
  "workbench.activityBar.location": "hidden",
  "window.menuBarVisibility": "compact",
  "window.commandCenter": false,
  "files.simpleDialog.enable": true,
  "claudeCode.preferredLocation": "panel",
  "workbench.editor.autoLockGroups": {
    "terminalEditor": false,
    "mainThreadWebview-simpleBrowser.view": false,
    "mainThreadWebview-browserPreview": false
  },
  "window.newWindowProfile": "Default"
}